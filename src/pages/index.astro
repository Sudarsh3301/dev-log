---
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";

const navItems = ["Blog", "Notes", "Lab", "Projects", "Papers", "Random"];
---

<Layout title={SITE.title} description={SITE.desc}>
  <main id="main-content" data-layout="index" class="home-layout app-layout">
    <h1>Hi, I'm Sudarsh.</h1>
    <p>
      I work on reasoning systems, inference optimization, and multimodal AI.
    </p>
    <p>
      Currently exploring efficient reasoning architectures, latent-space
      methods, and real-time AI systems.
    </p>
    <p>
      I like building systems that expose how models think rather than just what
      they output.
    </p>

    <nav class="home-nav" aria-label="Notebook sections">
      {navItems.map(item => <a href={`/${item.toLowerCase()}`}>{item}</a>)}
    </nav>
  </main>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
