---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SectionPostList from "@/components/SectionPostList.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { hasNotebookTag } from "@/utils/notebookPostFilter";
import { SITE } from "@/config";

const posts = await getCollection(
  "blog",
  ({ data }) =>
    hasNotebookTag(data.tags) &&
    data.tags.some(tag =>
      ["lab", "experiment", "experiments"].includes(tag.toLowerCase())
    )
);
---

<Layout title={`Lab | ${SITE.title}`} description="Experiments and prototypes.">
  <Header />
  <Main
    pageTitle="Lab"
    pageDesc="Ongoing experiments, prototypes, visualizations, and benchmarks."
  >
    <SectionPostList
      posts={getSortedPosts(posts)}
      emptyText="Lab notes and experiments will collect here."
    />
  </Main>
  <Footer />
</Layout>
