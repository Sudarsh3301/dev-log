---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SectionPostList from "@/components/SectionPostList.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { hasNotebookTag } from "@/utils/notebookPostFilter";
import { SITE } from "@/config";

const posts = await getCollection(
  "blog",
  ({ data }) =>
    hasNotebookTag(data.tags) &&
    data.tags.some(tag =>
      ["random", "books", "misc"].includes(tag.toLowerCase())
    )
);
---

<Layout
  title={`Random | ${SITE.title}`}
  description="Books, inspirations, and miscellaneous findings."
>
  <Header />
  <Main
    pageTitle="Random"
    pageDesc="Books, inspirations, thoughts, and miscellaneous findings."
  >
    <SectionPostList
      posts={getSortedPosts(posts)}
      emptyText="Miscellaneous notes will collect here."
    />
  </Main>
  <Footer />
</Layout>
