---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import SectionPostList from "@/components/SectionPostList.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { hasNotebookTag } from "@/utils/notebookPostFilter";
import { SITE } from "@/config";

const posts = await getCollection(
  "blog",
  ({ data }) =>
    hasNotebookTag(data.tags) &&
    data.tags.some(tag => ["note", "notes"].includes(tag.toLowerCase()))
);
---

<Layout
  title={`Notes | ${SITE.title}`}
  description="Short technical observations."
>
  <Header />
  <Main
    pageTitle="Notes"
    pageDesc="Short-form technical observations and fragments."
  >
    <SectionPostList
      posts={getSortedPosts(posts)}
      emptyText="Short notes will collect here."
    />
  </Main>
  <Footer />
</Layout>
